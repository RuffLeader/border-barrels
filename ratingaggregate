<div style="font-family: sans-serif; max-width: 400px; padding: 20px; border: 1px solid #ddd; border-radius: 10px;">
  <h3>🎬 Show Score Calculator</h3>
  
  <label>IMDb (0-10):</label>
  <input type="number" id="imdb" step="0.1" placeholder="8.2" style="width: 100%; margin-bottom: 10px;">
  
  <label>RT Critic (%):</label>
  <input type="number" id="rt_critic" placeholder="90" style="width: 100%; margin-bottom: 10px;">
  
  <label>RT Audience (%):</label>
  <input type="number" id="rt_audience" placeholder="85" style="width: 100%; margin-bottom: 10px;">
  
  <label>TMDB (0-10):</label>
  <input type="number" id="tmdb" step="0.1" placeholder="7.9" style="width: 100%; margin-bottom: 20px;">
  
  <button onclick="calculateScore()" style="width: 100%; padding: 10px; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer;">Calculate Score</button>

  <div style="margin-top: 20px; text-align: center;">
    <span style="font-size: 1.2rem;">Weighted Score:</span>
    <div id="result" style="font-size: 2.5rem; font-weight: bold; color: #007bff;">--</div>
  </div>
</div>

<script>
function calculateScore() {
  // Get values from inputs
  const imdb = parseFloat(document.getElementById('imdb').value) || 0;
  const rtc = parseFloat(document.getElementById('rt_critic').value) || 0;
  const rta = parseFloat(document.getElementById('rt_audience').value) || 0;
  const tmdb = parseFloat(document.getElementById('tmdb').value) || 0;

  // Apply your weights: 30% IMDb, 25% RT Critic, 25% RT Audience, 20% TMDB
  // Note: IMDb and TMDB are multiplied by 10 to normalize to 100
  const finalScore = (imdb * 10 * 0.30) + (rtc * 0.25) + (rta * 0.25) + (tmdb * 10 * 0.20);

  document.getElementById('result').innerText = finalScore.toFixed(1);
}
</script>
